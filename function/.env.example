# Inference API key. The hosted deployment uses Scaleway Generative APIs (EU) —
# get a key at https://console.scaleway.com (Generative APIs). Mistral's own API
# (https://console.mistral.ai) or a local Ollama work too; see MISTRAL_BASE_URL.
MISTRAL_API_KEY=
# Model id. On Scaleway: mistral-small-3.2-24b-instruct-2506. On Mistral's API: mistral-small-latest.
MISTRAL_MODEL=mistral-small-3.2-24b-instruct-2506
# OpenAI-compatible base URL. The SDK appends /v1/chat/completions, so do NOT include /v1.
#   Scaleway (EU):  MISTRAL_BASE_URL=https://api.scaleway.ai
#   Mistral's API:  leave unset
#   Local Ollama:   MISTRAL_BASE_URL=http://localhost:11434 with MISTRAL_MODEL=mistral-small3.2 and MISTRAL_API_KEY=ollama
MISTRAL_BASE_URL=https://api.scaleway.ai
# Public OSE MCP endpoint (Streamable HTTP), e.g. https://ose-mcp.xxxx.scw.cloud/http
OSE_MCP_URL=
# Comma-separated allowed origins, ENFORCED server-side (403 for any request
# whose Origin is missing or not listed), in addition to setting CORS headers.
# "*" disables the check (local dev only) — ALWAYS set the real static site
# origin in production, e.g. ALLOWED_ORIGINS=https://chat.example.org
ALLOWED_ORIGINS=*
# Max agent loop iterations (tool-call rounds)
MAX_TOOL_ROUNDS=4
# Server listen port (injected by the platform on Scaleway/containers)
# PORT=8080
