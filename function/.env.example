# Mistral La Plateforme (EU). Get a key at https://console.mistral.ai
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
# Optional: OpenAI-compatible base URL for a local/offline LLM (e.g. Ollama).
# The SDK appends /v1/chat/completions, so do NOT include /v1 here.
# Example: MISTRAL_BASE_URL=http://localhost:11434 with MISTRAL_MODEL=mistral-small3.2 and MISTRAL_API_KEY=ollama
MISTRAL_BASE_URL=
# Public OSE MCP endpoint (Streamable HTTP), e.g. https://ose-mcp.xxxx.scw.cloud/http
OSE_MCP_URL=
# Comma-separated allowed origins, ENFORCED server-side (403 for any request
# whose Origin is missing or not listed), in addition to setting CORS headers.
# "*" disables the check (local dev only) — ALWAYS set the real static site
# origin in production, e.g. ALLOWED_ORIGINS=https://chat.example.org
ALLOWED_ORIGINS=*
# Max agent loop iterations (tool-call rounds)
MAX_TOOL_ROUNDS=4
# Server listen port (injected by the platform on Scaleway/containers)
# PORT=8080
